# Alpha Vantage API Configuration (for real-time commodity prices)
# Get your free API key from: https://www.alphavantage.co/support/#api-key
# This is REQUIRED for real-time price updates in production
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key-here

# News API Configuration (for real-time war news)
# Get your free API key from: https://newsapi.org/
# This is REQUIRED for real-time news updates in production
NEWS_API_KEY=your-news-api-key-here

# Flask Secret Key
# Generate a random key for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Deployment Settings
# Set to 'true' for development mode, 'false' for production
DEBUG=False

# Port for Flask application (default: 5000)
PORT=5000